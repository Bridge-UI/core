{
  "private": true,
  "name": "bridge-ui-core",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "deps": "npm install",
    "build": "npm run build -w @bridge-ui/core && npm run build -w @bridge-ui/vue && npm run build -w @bridge-ui/react",
    "build:core": "npm run build -w @bridge-ui/core",
    "build:vue": "npm run build -w @bridge-ui/vue",
    "build:react": "npm run build -w @bridge-ui/react",
    "dev": "npm run dev -w @bridge-ui/vue & npm run dev -w @bridge-ui/react",
    "dev:vue": "npm run dev -w @bridge-ui/vue",
    "dev:react": "npm run dev -w @bridge-ui/react",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "install:vue": "npm install -w @bridge-ui/vue",
    "install:react": "npm install -w @bridge-ui/react",
    "type-check": "npm run type-check:core && npm run type-check:vue && npm run type-check:react",
    "type-check:core": "npm run type-check -w @bridge-ui/core",
    "type-check:vue": "npm run type-check -w @bridge-ui/vue",
    "type-check:react": "npm run type-check -w @bridge-ui/react",
    "test": "npm run test -w @bridge-ui/core && npm run test -w @bridge-ui/vue",
    "test:run": "npm run test:run -w @bridge-ui/core && npm run test:run -w @bridge-ui/vue",
    "test:core": "npm run test:run -w @bridge-ui/core",
    "test:vue": "npm run test:run -w @bridge-ui/vue",
    "test:cy:vue": "npm run test:cy -w @bridge-ui/vue",
    "test:cy:react": "npm run test:cy -w @bridge-ui/react",
    "lint": "eslint packages/vue/src packages/react/src packages/core/src",
    "lint:fix": "eslint packages/vue/src packages/react/src packages/core/src --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "cypress": "^15.15.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-vue": "^9.32.0",
    "happy-dom": "^20.9.0",
    "jiti": "^2.4.2",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.6",
    "vue-eslint-parser": "^9.4.3"
  }
}
