{
  "type": "module",
  "license": "MIT",
  "version": "0.0.0",
  "author": "BridgeUI",
  "sideEffects": false,
  "name": "@bridge-ui/core",
  "homepage": "https://github.com/Bridge-UI/core#readme",
  "description": "Shared types, design tokens, and utilities for Bridge UI.",
  "bugs": {
    "url": "https://github.com/Bridge-UI/core/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "directory": "packages/core",
    "url": "git+https://github.com/Bridge-UI/core.git"
  },
  "keywords": [
    "bridge-ui",
    "utilities",
    "components",
    "typescript",
    "design-system",
    "design-tokens"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./Config": {
      "import": "./dist/Config/index.js",
      "types": "./dist/Config/index.d.ts"
    },
    "./Utils": {
      "import": "./dist/Utils/index.js",
      "types": "./dist/Utils/index.d.ts"
    },
    "./Components/*/*": {
      "import": "./dist/Components/*/*.js",
      "types": "./dist/Components/*/*.d.ts"
    },
    "./Components/*": {
      "import": "./dist/Components/*/index.js",
      "types": "./dist/Components/*/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "clsx": "^2.1.1",
    "es-toolkit": "^1.46.1",
    "tailwind-merge": "^3.6.0"
  },
  "scripts": {
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3"
  }
}
