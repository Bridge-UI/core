{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "noEmit": true,
    "paths": {
      "@core/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/__tests__"]
}
