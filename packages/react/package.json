{
  "type": "module",
  "license": "MIT",
  "version": "0.0.1-beta.5",
  "author": "BridgeUI",
  "sideEffects": false,
  "name": "@bridge-ui/react",
  "homepage": "https://github.com/Bridge-UI/core#readme",
  "description": "React components and hooks for Bridge UI.",
  "bugs": {
    "url": "https://github.com/Bridge-UI/core/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "directory": "packages/react",
    "url": "git+https://github.com/Bridge-UI/core.git"
  },
  "keywords": [
    "ui",
    "react",
    "tailwind",
    "bridge-ui",
    "components",
    "design-system"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./Utils": {
      "import": "./dist/Utils/index.js",
      "types": "./dist/Utils/index.d.ts"
    },
    "./Provider": {
      "import": "./dist/Provider/index.js",
      "types": "./dist/Provider/index.d.ts"
    },
    "./Actions": {
      "import": "./dist/Actions/index.js",
      "types": "./dist/Actions/index.d.ts"
    },
    "./Components/*": {
      "import": "./dist/Components/*/index.js",
      "types": "./dist/Components/*/index.d.ts"
    },
    "./theme.css": {
      "style": "./dist/theme.css",
      "import": "./dist/theme.css",
      "default": "./dist/theme.css"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@bridge-ui/core": "^0.0.1-beta.5",
    "lucide-react": ">=1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "es-toolkit": "^1.46.1",
    "tailwind-merge": "^3.6.0"
  },
  "scripts": {
    "build": "vite build && cp src/theme.css dist/theme.css",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:cy": "cypress run --component",
    "test:cy:open": "cypress open --component"
  },
  "devDependencies": {
    "@bridge-ui/core": "*",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
