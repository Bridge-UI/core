{
  "type": "module",
  "version": "0.0.0",
  "name": "@bridge-ui/vue",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@bridge-ui/core": "*",
    "lucide-vue-next": ">=0.400.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "es-toolkit": "^1.46.1",
    "tailwind-merge": "^3.6.0"
  },
  "scripts": {
    "build": "vite build && cp src/theme.css dist/theme.css",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:cy": "cypress run --component",
    "test:cy:open": "cypress open --component",
    "type-check": "vue-tsc --noEmit"
  },
  "devDependencies": {
    "@bridge-ui/core": "*",
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^24.0.0",
    "@vue/test-utils": "^2.4.10",
    "lucide-vue-next": "^1.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vue": "^3.5.34",
    "vue-tsc": "^3.2.9"
  }
}
