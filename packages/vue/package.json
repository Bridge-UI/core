{
  "type": "module",
  "license": "MIT",
  "version": "0.0.1-beta.1",
  "author": "BridgeUI",
  "sideEffects": false,
  "name": "@bridge-ui/vue",
  "homepage": "https://github.com/Bridge-UI/core#readme",
  "description": "Vue components and composables for Bridge UI.",
  "bugs": {
    "url": "https://github.com/Bridge-UI/core/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "directory": "packages/vue",
    "url": "git+https://github.com/Bridge-UI/core.git"
  },
  "keywords": [
    "ui",
    "vue",
    "tailwind",
    "bridge-ui",
    "components",
    "design-system"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./Utils": {
      "import": "./dist/Utils/index.js",
      "types": "./dist/Utils/index.d.ts"
    },
    "./Provider": {
      "import": "./dist/Provider/index.js",
      "types": "./dist/Provider/index.d.ts"
    },
    "./Actions": {
      "import": "./dist/Actions/index.js",
      "types": "./dist/Actions/index.d.ts"
    },
    "./Components/*": {
      "import": "./dist/Components/*/index.js",
      "types": "./dist/Components/*/index.d.ts"
    },
    "./theme.css": {
      "style": "./dist/theme.css",
      "import": "./dist/theme.css",
      "default": "./dist/theme.css"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@bridge-ui/core": "^0.0.1-beta.1",
    "lucide-vue-next": ">=0.400.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "es-toolkit": "^1.46.1",
    "tailwind-merge": "^3.6.0"
  },
  "scripts": {
    "build": "vite build && cp src/theme.css dist/theme.css",
    "dev": "vite build --watch",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:cy": "cypress run --component",
    "test:cy:open": "cypress open --component"
  },
  "devDependencies": {
    "@bridge-ui/core": "*",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.0.0",
    "@vue/language-core": "^3.2.9",
    "@vue/test-utils": "^2.4.10",
    "lucide-vue-next": "^1.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vue": "^3.5.34",
    "vue-tsc": "^3.2.9"
  }
}
